{
  "name": "@taleforge/app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:harness": "VITE_BATTLE_MAP_HARNESS=1 VITE_SUPABASE_URL=http://127.0.0.1:54321 VITE_SUPABASE_ANON_KEY=e2e-harness-key vite",
    "preview": "vite preview",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run tests/integration --config vitest.integration.config.ts",
    "assets:provenance": "node scripts/record-asset-provenance.mjs",
    "assets:normalize": "node scripts/normalize-character-assets.mjs",
    "assets:validate": "node scripts/validate-character-assets.mjs",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots=all"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@supabase/supabase-js": "^2.110.2",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^8.2.0",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@playwright/test": "1.61.1",
    "@react-three/test-renderer": "9.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "26.1.1",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "meshoptimizer": "^1.2.0",
    "pngjs": "7.0.0",
    "supabase": "^2.109.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
